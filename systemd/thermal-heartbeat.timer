[Unit]
Description=Tick thermal-heartbeat.service every 60s
Requires=thermal-heartbeat.service

[Timer]
# 60s cadence: half the rate of vmagent's 30s scrape_interval, which is
# fine for thermal samples and keeps Sentry cron check-ins inside the
# error budget.
OnBootSec=60s
OnUnitActiveSec=60s
AccuracySec=1s
Persistent=true

[Install]
WantedBy=timers.target
