[Unit]
Description=Daily tick for personal-dashboard-update.service
Requires=personal-dashboard-update.service

[Timer]
# 03:30 local time daily. Staggered behind coily-update (03:00) so the
# two don't fight over brew's update lock.
OnCalendar=*-*-* 03:30:00
RandomizedDelaySec=600
Persistent=true

[Install]
WantedBy=timers.target
