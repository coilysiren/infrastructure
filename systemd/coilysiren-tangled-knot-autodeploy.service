[Unit]
Description=Autodeploy the Tangled knot (tangled.coilysiren.me)
After=network-online.target tangled-knot.service
Wants=network-online.target
Requires=tangled-knot.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/root
ExecStart=/home/kai/projects/coilysiren/infrastructure/scripts/coilysiren-tangled-knot-autodeploy.sh

[Install]
WantedBy=multi-user.target
