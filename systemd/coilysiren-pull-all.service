[Unit]
Description=Fast-forward every coilysiren git checkout on kai-server
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=kai
WorkingDirectory=/home/kai
ExecStart=/home/kai/projects/coilysiren/infrastructure/scripts/coilysiren-pull-all.sh

[Install]
WantedBy=multi-user.target
