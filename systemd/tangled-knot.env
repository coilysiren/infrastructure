# Tangled knot config. Installed to /etc/tangled-knot/knot.env, read by
# tangled-knot.service as an EnvironmentFile. Mirrors the env the
# upstream NixOS knot module sets. See infrastructure#280.

# Appview this knot registers with.
APPVIEW_ENDPOINT=https://tangled.org

# Public hostname (HTTP/XRPC, fronted by Caddy) and owner DID.
KNOT_SERVER_HOSTNAME=tangled.coilysiren.me
KNOT_SERVER_OWNER=did:plc:xvgmere7jp42xfc5xn47lvyi

# Listen on loopback only - Caddy reverse-proxies tangled.coilysiren.me
# to :5555, so the knot is never directly exposed.
KNOT_SERVER_LISTEN_ADDR=127.0.0.1:5555
KNOT_SERVER_INTERNAL_LISTEN_ADDR=127.0.0.1:5444

KNOT_SERVER_DB_PATH=/var/lib/tangled-knot/knotserver.db
KNOT_SERVER_PLC_URL=https://plc.directory
KNOT_SERVER_JETSTREAM_ENDPOINT=wss://jetstream1.us-west.bsky.network/subscribe
KNOT_SERVER_LOG_DIDS=true
KNOT_SERVER_DEV=false
KNOT_SERVER_MAX_RESPONSE_KB=5120

# Repo storage and git committer identity.
KNOT_REPO_SCAN_PATH=/var/lib/tangled-knot/repos
KNOT_REPO_MAIN_BRANCH=main
KNOT_GIT_USER_NAME=Tangled
KNOT_GIT_USER_EMAIL=noreply@tangled.org

KNOT_MIRRORS=https://mirror.tangled.network
