[Unit]
Description=Claude Code remote-control daemon (kai-server, outbound HTTPS only)
After=syslog.target network.target nss-lookup.target network-online.target
Wants=network-online.target
# Self-heal: never latch into a permanent `failed` state. A node/nvm bump
# can briefly orphan the global `claude` (exec: not found, exit 127); with
# the start-rate limit disabled the unit keeps retrying every RestartSec
# and recovers on its own once kai-server-node-tooling-ensure.service
# reinstalls the global under the new node. Before this, StartLimitBurst=5
# turned a one-minute orphan into a full-day outage that needed a manual
# `systemctl reset-failed`.
StartLimitIntervalSec=0

[Service]
Type=simple
# Restart=always (not on-failure): a >10min network outage makes the daemon
# exit cleanly (status 0), which on-failure would NOT restart. RestartSec=30
# keeps the retry loop from spamming the journal while claude is orphaned.
Restart=always
RestartSec=30
User=kai
# projects/coilysiren is the parent of git repos, not a repo itself, so
# `--spawn worktree` cannot apply. All three hosts (kai-server, WSL,
# Windows-native) now operate on the projects/coilysiren parent dir
# with --spawn same-dir for consistency.
WorkingDirectory=/home/kai/projects/coilysiren
# `claude` is the npm-installed CLI under nvm. Source nvm.sh to pick up
# whichever node version nvm has set as default for kai, then exec so
# systemd tracks the claude process directly (no bash wrapper holding
# MAINPID). `claude login` must have been run once as kai with the
# active claude.ai subscription.
Environment=HOME=/home/kai
Environment=NVM_DIR=/home/kai/.nvm
# `--name` labels the pre-created session inside the daemon.
# `--remote-control-session-name-prefix` drives the bottom line of the
# claude.ai/code Remote Control dropdown row (default is `hostname`,
# which happens to be `kai-server` here but we set it explicitly so the
# dropdown stays correct if the host is ever renamed).
ExecStart=/bin/bash -c 'source $NVM_DIR/nvm.sh && exec claude remote-control --spawn same-dir --name kai-server --remote-control-session-name-prefix kai-server'
ExecStop=/bin/kill -TERM $MAINPID

[Install]
WantedBy=multi-user.target
