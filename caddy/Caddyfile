# The Caddyfile is an easy way to configure your Caddy web server.
#
# Unless the file starts with a global options block, the first
# uncommented line is always the address of your site.
#
# To use your own domain name (with automatic HTTPS), first make
# sure your domain's A/AAAA DNS records are properly pointed to
# this machine's public IP, then replace ":80" below with your
# domain name.

# Public-domain site blocks intentionally absent. Host Caddy is
# tailnet-internal; public *.coilysiren.me traffic goes through Traefik
# (k3s). api.coilysiren.me was deprovisioned. tangled.coilysiren.me is
# served via a Traefik Ingress, see deploy/tangled-knot-ingress.yml.

# Static file serve for the coily audit dashboard. Regenerated every
# 5 minutes by coily-audit-dashboard.timer to /var/lib/coily/. Tailnet-
# internal only - no TLS, no auth, since the file already contains
# operator-private audit data and only authenticated tailnet peers can
# reach this port.
:8082 {
    root * /var/lib/coily
    file_server
}

# Tailnet shortcuts to cluster services. Hostname is the bare MagicDNS
# name (kai-server), reached over the tailnet. Each `handle_path` block
# under sites/*.caddy is generated by scripts/generate-caddy-shortcuts.py
# from a sibling repo's config.yml tailnet.shortcut field. Snippets
# reverse_proxy to Traefik with the right Host header so the cluster's
# existing per-Ingress routing does the rest. Public traffic still flows
# through Traefik directly via 192.168.0.194:80/443 and is not affected
# by this block.
http://kai-server {
    # sites/*.caddy is generated by scripts/generate-caddy-shortcuts.py.
    # sites-manual/*.caddy is hand-written for shortcuts that don't fit
    # the "reverse_proxy to Traefik" pattern (static file serves, local
    # daemons that aren't in k3s, etc). Both globs are imported so a
    # mixed-source single front door stays simple.
    import sites/*.caddy
    import sites-manual/*.caddy
}

:80 {
	# Set this path to your site's directory.
	root * /usr/share/caddy

	# Enable the static file server.
	file_server

	# Another common task is to set up a reverse proxy:
	# reverse_proxy localhost:8080

	# Or serve a PHP site through php-fpm:
	# php_fastcgi localhost:9000
}

# Refer to the Caddy docs for more information:
# https://caddyserver.com/docs/caddyfile
