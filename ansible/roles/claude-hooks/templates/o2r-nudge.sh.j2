#!/usr/bin/env bash
# Advisory PreToolUse nudge. When a Bash command targets another fleet node,
# remind the agent to route agent-to-agent delivery over o2r (otel-a2a-relay)
# via the kai-command-handover skill, never a pasted command or URL. Non-blocking:
# it only injects context, the command still runs through normal permissioning.
#
# Managed by ansible (roles/claude-hooks); edit the .j2 template, not this copy.
set -euo pipefail

cmd="$(jq -r '.tool_input.command // empty' 2>/dev/null || true)"
[ -z "$cmd" ] && exit 0

hosts='{{ o2r_nudge_fleet_hosts | join("|") }}'
hit=0

# Strip single- and double-quoted spans before matching. ssh/scp/rsync words and
# fleet host names routinely ride inside quoted args that are NOT node-targeting
# invocations - issue titles ("...ssh on kai-desktop-tower"), --description "SSH
# public key...", commit/issue bodies. A real `ssh kai@host` invocation is
# unquoted and survives the strip. Without this, the raw-command match false-fired
# on nearly every `coily ops aws/forgejo` call during the 2026-06-05 sshd work.
stripped="$(printf '%s' "$cmd" | sed -E "s/'[^']*'//g; s/\"[^\"]*\"//g")"

# ssh/scp/rsync as a command word, plus a fleet host or the kai@ remote user.
# (coily's ssh passthrough was removed, so any ssh is bare - agentic-os-kai
# AGENTS, "SSH into kai-server".) The trailing [[:space:]]|$ already spares
# ssh-keygen / ssh-add / ssh-public-key (hyphen, not space, follows).
if printf '%s' "$stripped" | grep -Eiq '(^|[^[:alnum:]_-])(ssh|scp|rsync)([[:space:]]|$)'; then
  printf '%s' "$stripped" | grep -Eiq "(kai@|${hosts})" && hit=1
fi

[ "$hit" -eq 0 ] && exit 0

reason='This Bash command targets another fleet node. If this is agent-to-agent command delivery, route it over o2r (otel-a2a-relay) via the kai-command-handover skill: file a verifiable request envelope, never hand over a pasted command or URL (a handwritten URL is refused at the relay). Direct ops you run yourself, or a command handed to a human operator, may proceed.'
jq -cn --arg r "$reason" '{hookSpecificOutput: {hookEventName: "PreToolUse", additionalContext: $r}}'
exit 0
