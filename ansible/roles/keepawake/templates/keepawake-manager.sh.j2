#!/bin/bash
# {{ ansible_managed }}
# keepawake manager - one reconcile tick. Computes the desired SleepDisabled
# state from (time-of-day + battery%) and applies it via pmset. Managed by the
# `keepawake` Ansible role; edit the role template, not this installed copy.
set -euo pipefail
FLOOR={{ keepawake_floor_pct }}
MAINT_HOUR="{{ keepawake_maint_hour }}"
LOG="{{ keepawake_log }}"

hour=$(date +%H)
batt=$(pmset -g batt 2>/dev/null || true)
if printf '%s' "$batt" | grep -q "AC Power"; then on_ac=1; else on_ac=0; fi
pct=$(printf '%s' "$batt" | grep -Eo '[0-9]+%' | head -1 | tr -d '%')
[ -z "${pct:-}" ] && pct=100

# Default: hold the system awake. Released by the maintenance window or the
# battery floor below.
desired=1
reason=default-hold
if [ "$hour" = "$MAINT_HOUR" ]; then desired=0; reason=maint-window; fi
if [ "$on_ac" -eq 0 ] && [ "$pct" -lt "$FLOOR" ]; then desired=0; reason=battery-floor; fi

current=$(pmset -g | awk '/SleepDisabled/{print $2}')
[ -z "${current:-}" ] && current=0
if [ "$current" != "$desired" ]; then
  pmset -a disablesleep "$desired"
  printf '%s set disablesleep=%s (was %s) reason=%s ac=%s batt=%s%%\n' \
    "$(date '+%Y-%m-%dT%H:%M:%S')" "$desired" "$current" "$reason" "$on_ac" "$pct" >> "$LOG"
fi
