# Managed by ansible (infrastructure/ansible/roles/agent-compose). Do not
# hand-edit: change group_vars / role defaults and re-converge with
# `ward exec ansible-sync action=apply tags=agent-compose`.
#
# Presence of this file activates agent-compose. It composes COMPOSED.md from
# the sources below and points each harness global load point at it by symlink.
# Per-host source selection (set in Ansible group_vars) scopes the fleet, so the
# composer's own scope-filtering is left off (no scopes key).
sources:
{% for source in agent_compose_sources %}
  - {{ source }}
{% endfor %}
{% if agent_compose_roots | default([]) | length > 0 %}
roots:
{% for root in agent_compose_roots %}
  - {{ root }}
{% endfor %}
{% endif %}
load_points:
  claude: {{ agent_compose_load_points.claude }}
  codex: {{ agent_compose_load_points.codex }}
{% if agent_compose_load_points.opencode | default('') | length > 0 %}
  opencode: {{ agent_compose_load_points.opencode }}
{% endif %}
